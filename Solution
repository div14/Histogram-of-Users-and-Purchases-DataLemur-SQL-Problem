WITH new AS
(SELECT 
  transaction_date,
  user_id,
  product_id,
  DENSE_RANK() OVER(PARTITION BY user_id 
                    ORDER BY transaction_date DESC) AS rnk
FROM user_transactions)

SELECT 
  transaction_date, 
  user_id, 
  COUNT(product_id) AS purchase_count
FROM new
WHERE rnk=1
GROUP BY user_id
ORDER BY transaction_date 


